# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Git history — never needed in Docker
.git

# Dependencies — root and all nested packages
**/node_modules

# Build outputs — root and all nested packages
**/build
**/.next
out

# Turbo cache — root and all nested packages
**/.turbo

# React Router generated types
**/.react-router

# Test packages — not needed for the app build
packages/app-tests

# Local env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Misc
.DS_Store
*.pem
coverage
.pnp
.pnp.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Vercel
.vercel
